#!/bin/bash
# /etc/cron.d/blockpools-social-tags-refresh
# Rebuilds user_tags_by_league (🔥 Hot / 🔮 Sharp) every 20 minutes.
# Deployed to VPS via git pull — do not edit directly on server.
#
# Install: sudo cp crons/blockpools-social-tags-refresh /etc/cron.d/ && sudo chmod 644 /etc/cron.d/blockpools-social-tags-refresh

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
MAILTO=""

# ┌─────────── minute (every 20 min: 0, 20, 40)
# │      ┌──────── hour (*)
# │      │  ┌───── day of month (*)
# │      │  │  ┌── month (*)
# │      │  │  │  ┌─ day of week (*)
# │      │  │  │  │
*/20    *  *  *  *  root  /opt/blockpools/crons/social-tags-refresh.sh >> /var/log/blockpools/social-tags-refresh.log 2>&1
